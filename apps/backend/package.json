    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1",
    "@prisma/client": "^6.2.1",
    "redis": "^4.7.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.7",
    "morgan": "^1.10.0",
    "compression": "^1.7.5",
    "@stellar/stellar-sdk": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
